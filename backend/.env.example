# Copiá este archivo a ".env" y completá los valores.

# Clave de Anthropic (Claude). https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Modelo a usar (opcional). Default: claude-haiku-4-5
MODEL=claude-haiku-4-5

# PostgreSQL (DigitalOcean Managed). En el droplet usar el host PRIVADO/VPC.
DATABASE_URL=postgresql://USER:PASS@HOST:25060/defaultdb?sslmode=require

# Secretos de la app de Monday (Developer Center → App → Secrets):
# - SIGNING_SECRET valida el JWT de la receta (acción /monday/extract)
# - CLIENT_SECRET valida el session token de la vista (endpoints /api/config)
MONDAY_SIGNING_SECRET=
MONDAY_CLIENT_SECRET=

# Puerto del backend (opcional). Default: 8080
PORT=8080
# Tope de facturas por cuenta/mes (0 o vacío = sin límite). Base del freemium.
FREE_MONTHLY_LIMIT=0
